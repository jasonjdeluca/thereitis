# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local

# Environment credentials — never commit
.env

# Runtime report artifacts
reports/

# Ingestion pipeline runtime artifacts (SQLite queue + raw transcripts)
# Keep the directory tracked via .gitkeep, ignore everything else.
data/*
!data/.gitkeep

# Company-pack runtime artifacts (raw PDFs, extracted text, intermediate candidates)
# The generated/ subdirectory is intentionally committed; everything else is runtime.
company-packs/*/transcripts/
company-packs/*/extracted/
company-packs/*/candidate_phrases.json

# Test artifacts
test-results/

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
